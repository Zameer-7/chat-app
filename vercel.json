{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://chat-app-als4.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://chat-app-als4.onrender.com/uploads/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
